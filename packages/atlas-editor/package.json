{
  "name": "@atlas/atlas-editor",
  "version": "0.1.0",
  "description": "Framework-independent editor orchestration runtime for Atlas Studio.",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "ARCHITECTURE.md",
    "API.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "PERFORMANCE.md",
    "RELEASE_CERTIFICATION.md",
    "REVIEW_REPORT.md",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc -p tsconfig.test.json"
  },
  "dependencies": {
    "@atlas/atlas-command": "file:../atlas-command",
    "@atlas/atlas-core": "file:../atlas-core",
    "@atlas/atlas-document": "file:../atlas-document",
    "@atlas/atlas-events": "file:../atlas-events",
    "@atlas/atlas-history": "file:../atlas-history",
    "@atlas/atlas-input": "file:../atlas-input",
    "@atlas/atlas-interaction": "file:../atlas-interaction",
    "@atlas/atlas-plugin": "file:../atlas-plugin",
    "@atlas/atlas-renderer": "file:../atlas-renderer",
    "@atlas/atlas-selection": "file:../atlas-selection",
    "@atlas/atlas-types": "file:../atlas-types",
    "@atlas/atlas-ui": "file:../atlas-ui"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
